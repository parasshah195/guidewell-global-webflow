{
  "extends": "@finsweet/tsconfig",
  "compilerOptions": {
    "module": "ESNext",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "$utils/*": ["src/utils/*"],
      "$types/*": ["src/types/*"],
      "$dev/*": ["src/dev/*"],
      "$api/*": ["src/api/*"],
      "$stores/*": ["src/stores/*"],
      "$constants": ["src/constants.ts"]
    }
  }
}
